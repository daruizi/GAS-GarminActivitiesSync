# Garmin 中国区账号
GARMIN_USERNAME=
GARMIN_PASSWORD=

# Garmin 国际区账号
GARMIN_GLOBAL_USERNAME=
GARMIN_GLOBAL_PASSWORD=

# 同步/迁移配置
GARMIN_SYNC_NUM=10
GARMIN_MIGRATE_NUM=100
GARMIN_MIGRATE_START=0

# 数据库加密密钥（必填，请设置复杂密钥）
AESKEY=

# Bark 推送通知（可选）
BARK_KEY=

# RunningQuotient 配置（可选）
RQ_USERID=
RQ_COOKIE=
RQ_CSRF_TOKEN=

# Google Sheets 配置（可选）
GOOGLE_SHEET_ID=
GOOGLE_API_CLIENT_EMAIL=
GOOGLE_API_PRIVATE_KEY=